# ─────────────────────────────────────────────────────────────────────────────
# App Environment — Self-hosted Supabase
#
# After running  bash deploy/scripts/01-generate-keys.sh  copy the output
# ANON_KEY here, and set SUPABASE_URL to your server's domain.
#
# In the project root, rename this file:
#   cp .env.selfhosted.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Self-hosted endpoint (replace with your actual domain) ────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://api.yourdomain.com
VITE_SUPABASE_URL=https://api.yourdomain.com

# ── Anon key generated by deploy/scripts/01-generate-keys.sh ─────────────────
EXPO_PUBLIC_SUPABASE_ANON_KEY=<PASTE_ANON_KEY_FROM_GENERATE_SCRIPT>
VITE_SUPABASE_ANON_KEY=<PASTE_ANON_KEY_FROM_GENERATE_SCRIPT>